NODE_ENV=development
TRACELLM_PORT=4319
TRACELLM_PUBLIC_API_URL=http://localhost:4319
TRACELLM_DB_PATH=./data/tracellm.sqlite
TRACELLM_AUTH_REQUIRED=false
TRACELLM_AUTH_COOKIE_NAME=tracellm_session
TRACELLM_AUTH_COOKIE_SECURE=false
TRACELLM_JWT_ISSUER=tracellm
TRACELLM_JWT_AUDIENCE=tracellm-web
TRACELLM_JWT_TTL_SECONDS=604800
TRACELLM_DEV_API_KEY=trllm_dev_key
TRACELLM_OTEL_ENABLED=true
TRACELLM_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
TRACELLM_OTEL_EXPORTER_OTLP_HEADERS=
TRACELLM_SERVICE_NAME=tracellm-server
TRACELLM_CAPTURE_CONTENT=false
TRACELLM_EXPORT_SECRET_KEY=tracellm-local-export-secret-change-me
