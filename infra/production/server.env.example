NODE_ENV=production
TRACELLM_PORT=4319
TRACELLM_PUBLIC_API_URL=https://api.tracellm.in
TRACELLM_DB_PATH=/app/data/tracellm.sqlite

TRACELLM_AUTH_REQUIRED=true
TRACELLM_AUTH_COOKIE_NAME=tracellm_session
TRACELLM_AUTH_COOKIE_SECURE=true
TRACELLM_JWT_ISSUER=tracellm
TRACELLM_JWT_AUDIENCE=tracellm-web
TRACELLM_JWT_TTL_SECONDS=604800
TRACELLM_DEV_API_KEY=replace-with-random-disabled-production-value

TRACELLM_OTEL_ENABLED=true
TRACELLM_OTEL_EXPORTER_OTLP_ENDPOINT=http://signoz-ingester:4318
TRACELLM_OTEL_EXPORTER_OTLP_HEADERS=
TRACELLM_SERVICE_NAME=tracellm-server
TRACELLM_CAPTURE_CONTENT=false

TRACELLM_EXPORT_SECRET_KEY=replace-with-strong-stable-secret
