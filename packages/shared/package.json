{
  "name": "@tracellm/shared",
  "version": "0.1.0",
  "description": "Shared schemas and types for TraceLLM packages.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jyotishmoy12/tracellm.git",
    "directory": "packages/shared"
  },
  "homepage": "https://docs.tracellm.in",
  "bugs": {
    "url": "https://github.com/Jyotishmoy12/tracellm/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"No shared tests yet\""
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
